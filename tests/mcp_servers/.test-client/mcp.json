{
    "mcpServers": {
        "Weather": {
            "command": "uv run python",
            "args": ["tests/mcp_servers/weather_server.py"]
        },
        "Math": {
            "command": "uv run python",
            "args": ["tests/mcp_servers/math_server.py"]
        },
        "Invalid": {
            "command": "uv run python",
            "args": ["-c", "'raise Exception(\"Invalid Server\")'"]
        },
        "Vendor": {
            "command": "~/Library/Application Support/vendor/vscode-cli/vendor-macos-arm64",
            "args": [
              "mcp",
              "-t",
              "stdio"
            ],
            "env": {
              "AGENT_SCAN_API": "https://hooks.example.com",
              "TRUSTED_FOLDERS": "~/Documents/vendor/agent-scan-backend;~/Documents/personal/probable-spork-web",
              "IDE_CONFIG_PATH": "Cursor"
            }
        }
    }
}
